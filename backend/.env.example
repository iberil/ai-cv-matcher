# Database Configuration
# Neon Tech Serverless PostgreSQL
DATABASE_URL=postgresql://neondb_owner:password@ep-name.eu-central-1.aws.neon.tech/neondb?sslmode=require

# JWT Configuration
JWT_SECRET_KEY=your-super-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Hugging Face API Configuration (for CV analysis and career coaching)
HF_TOKEN=your-huggingface-api-token-here
HF_MODEL=Qwen/Qwen2.5-72B-Instruct
HF_API_URL=https://api-inference.huggingface.co/v1/chat/completions

# Application Settings
APP_NAME=CV-Matcher API
APP_VERSION=1.0.0
DEBUG=True

# CORS Settings
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# File Upload Settings
MAX_UPLOAD_SIZE=52428800
UPLOAD_DIR=uploads
TEMP_DIR=temp_uploads

# Storage Configuration (S3 or Cloudflare R2)
AWS_ACCESS_KEY_ID=your-key
AWS_SECRET_ACCESS_KEY=your-secret
AWS_STORAGE_BUCKET_NAME=your-bucket
AWS_S3_REGION_NAME=us-east-1

# Email Configuration (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Redis Configuration (optional, for caching)
REDIS_URL=redis://localhost:6379/0

# Logging
LOG_LEVEL=INFO
LOG_FILE=app.log
